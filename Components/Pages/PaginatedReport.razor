@page "/paginated"
@rendermode InteractiveServer

<PageTitle>Paginated report</PageTitle>

<div class="report-page">
    <h1>Paginated report</h1>
    <p class="hint">
        Microsoft does not support <code>loaded</code> / <code>rendered</code> for paginated embeds —
        the sample uses a short heuristic timer after embed (see <code>powerbi-embed.js</code>).
    </p>

    <RlsEffectiveIdentityDemo Kind="EmbedReportKind.Paginated"
                              KeyPrefix="paginated"
                              AdditionalHint='For V2 tokens against semantic models, set PowerBi:PaginatedDatasetIds in appsettings (JSON array of dataset GUIDs).' />
</div>
