@rendermode InteractiveServer
@inject PowerBiEmbedService EmbedService
@inject IHostEnvironment HostEnv
@inject IOptions<PowerBiOptions> PbiOptions
@inject IJSRuntime JS
@inject ILogger<PowerBiReportViewer> Logger

<section class="viewer-wrap">
    <header class="viewer-header">
        <span class="badge">@Kind</span>
        @if (_config is not null)
        {
            <span class="timings">
                Server timings (ms):
                @foreach (var kv in _config.TimingsMs)
                {
                    <code>@kv.Key=@kv.Value</code>
                }
                · mode: @_config.TokenMode
            </span>
        }
    </header>

    @if (_config?.EffectiveIdentity is { } idEcho)
    {
        <div class="identity-echo" role="status">
            <strong>Effective identity sent to Power BI</strong>
            (echo from server — matches <code>identities[]</code> on GenerateToken):
            <code>username=@idEcho.Username</code>
            @if (idEcho.Roles is { Count: > 0 } r)
            {
                <span>· roles=@string.Join(", ", r)</span>
            }
            @if (idEcho.DatasetIds is { Count: > 0 } ds)
            {
                <span>· datasets=@string.Join(", ", ds)</span>
            }
        </div>
    }

    @if (_error is not null)
    {
        <div class="alert" role="alert">@_error</div>
    }
    else if (_loading)
    {
        <p class="loading">Loading embed configuration…</p>
    }

    <div id="@_containerId" class="embed-host @( _loading ? "embed-host--hidden" : null )"></div>

    @if (_clientTiming is not null)
    {
        <p class="client-timing">Client embed phase: @_clientTiming</p>
    }
</section>

@code {
    [Parameter, EditorRequired]
    public EmbedReportKind Kind { get; set; }

    [Parameter]
    public string? EffectiveUsername { get; set; }

    [Parameter]
    public string? EffectiveRoles { get; set; }

    private readonly string _containerId = "pbi-" + Guid.NewGuid().ToString("n");
    private bool _loading = true;
    private string? _error;
    private EmbedConfigDto? _config;
    private string? _clientTiming;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        try
        {
            if (!EmbedConfigRequestHelper.TryBuildEffectiveIdentity(
                    EffectiveUsername,
                    EffectiveRoles,
                    HostEnv,
                    PbiOptions.Value,
                    out var identity,
                    out var identityError))
            {
                _error = identityError;
                _loading = false;
                StateHasChanged();
                return;
            }

            _config = await EmbedService.GetEmbedConfigAsync(Kind, identity, default);
            if (string.IsNullOrEmpty(_config.EmbedToken))
            {
                _error = "Empty embed configuration (no token).";
                _loading = false;
                StateHasChanged();
                return;
            }

            _loading = false;
            StateHasChanged();

            await Task.Delay(50);

            var fn = Kind == EmbedReportKind.Semantic ? "pbiEmbed.embedSemantic" : "pbiEmbed.embedPaginated";
            var result = await JS.InvokeAsync<System.Text.Json.JsonElement>(
                fn,
                _containerId,
                _config.EmbedUrl,
                _config.EmbedToken,
                _config.ReportId);

            if (result.ValueKind == System.Text.Json.JsonValueKind.Object &&
                result.TryGetProperty("clientMs", out var ms))
                _clientTiming = $"~{ms.GetInt32()} ms ({result.GetProperty("signal").GetString()})";
            else
                _clientTiming = result.ToString();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Embed failed");
            _error = EmbedConfigRequestHelper.FormatEmbedExceptionMessage(ex);
            _loading = false;
        }

        StateHasChanged();
    }
}
